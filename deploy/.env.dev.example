# Variables de ejemplo para desarrollo

# Clave secreta (cambia esto en tu entorno)
SECRET_KEY=dev_change_me

# Base de datos de metadatos (PostgreSQL recomendado en dev)
# Formato: postgresql+psycopg2://usuario:password@host:puerto/base
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://superset:superset@localhost:5432/superset

# Redis para caché/colas
REDIS_HOST=localhost
REDIS_PORT=6379

# Config opcional: ruta a un superset_config.py personalizado
# SUPERSET_CONFIG_PATH=/ruta/absoluta/a/deploy/superset_config.py
