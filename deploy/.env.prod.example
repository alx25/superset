# Variables de ejemplo para producción

# Cambia esta clave por una segura y mantenla en secreto
SECRET_KEY=prod_change_me_to_a_strong_secret

# Base de datos de metadatos (usa un servicio administrado o gestionado por ti con backups)
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://superset:strong_password@db.example.com:5432/superset

# Redis para caché/colas
REDIS_HOST=redis.example.com
REDIS_PORT=6379

# Tiempo de sesión, cookies seguras, etc. (puede ir en superset_config.py)
# SUPERSET_WEBSERVER_TIMEOUT=120
# ENABLE_PROXY_FIX=true

# Config opcional: ruta a un superset_config.py personalizado
# SUPERSET_CONFIG_PATH=/etc/superset/superset_config.py
